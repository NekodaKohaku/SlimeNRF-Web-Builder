/ {
	chosen {
		zephyr,code-partition = &slot0_partition;
	};
};

&cpuapp_rram {
	/delete-node/ partitions;
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot0_partition: partition@0 {
			label = "image-0";
			reg = <0x00000000 0x0015c000>;
		};

		storage_partition: partition@15c000 {
			label = "storage";
			reg = <0x0015c000 0x00009000>;
		};
	};
};
